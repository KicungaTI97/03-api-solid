{
  "formatter": {
    "indentStyle": "space", // o padrĂŁo ĂŠ `tab`
    "lineWidth": 100 // o padrĂŁo ĂŠ `80`
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single", // o padrĂŁo ĂŠ `double`
      "lineWidth": 120 // sobrescreve `formatter.lineWidth`
    }
  },
  "json": {
    "formatter": {
      "enabled": false
    }
  }
}