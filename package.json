    "@vitest/coverage-v8": "4.0.12",
    "@vitest/ui": "4.0.12",
    "prisma": "6.0.0",
    "supertest": "7.1.4",
    "tsup": "8.5.1",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
